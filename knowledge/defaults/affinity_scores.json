{
  "_description": "Affinity scores for structure selection. For each structure: gates (hard filters on market state) and per-dimension scores. Total score = sum across dimensions. Overlays are ranked separately from primary structures.",

  "_scoring_scale": "0 = neutral / not relevant, 1 = slightly attractive, 2 = attractive, 3 = highly attractive",

  "_gates_schema": {
    "target_z_abs_min": "Minimum absolute target_z required for this structure to be eligible. Structures that require a specific target (requires_target=true in structure_profiles.json) use this to exclude cases where the target is too close to the forward to be meaningful. Value is in σ units (e.g. 0.5 means target must be at least 0.5σ from the forward).",
    "target_z_abs_max": "Maximum absolute target_z allowed for this structure to be eligible. Use this to exclude structures where the target is so far from the forward that the structure becomes inefficient (e.g. spread sold strike near worthless above 2.5σ). Value is in σ units."
  },

  "_bucket_labels": {
    "target_z_abs":  ["no_target", "near (<0.5σ)", "moderate (0.5–1.5σ)", "extended (1.5–2.5σ)", "far (>2.5σ)"],
    "carry_regime":  ["0 (noisy)", "1 (potential)", "2 (high carry)"],
    "atmfsratio":    ["no_carry", "low (<2)", "medium (2–4)", "high (>4)"]
  },

  "thresholds": {
    "target_z_abs": [0.5, 1.5, 2.5],
    "atmfsratio":   [2.0, 4.0]
  },

